# Crop Advisory System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# ============================================
# JWT SECRET KEY (Important: Change in production!)
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# ============================================
# OPENWEATHERMAP API CONFIGURATION
# ============================================
# Get your free API key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Weather API settings (optional)
WEATHER_API_TIMEOUT=10
WEATHER_API_UNITS=metric
ENABLE_FALLBACK_MOCK_DATA=True

# Default location (used when no location provided)
DEFAULT_LAT=28.6139
DEFAULT_LON=77.2090
DEFAULT_CITY=Delhi

# ============================================
# NUTRIENT ESTIMATOR CONFIGURATION
# ============================================
NUTRIENT_MODEL_PATH=nutrient_model.pkl
ENABLE_AUTO_NUTRIENT_ESTIMATION=True

# ============================================
# DATABASE (optional)
# ============================================
DATABASE_PATH=crop.db

# ============================================
# PRODUCTION SETTINGS
# ============================================
# For production, use:
# FLASK_ENV=production
# FLASK_DEBUG=False
# JWT_SECRET_KEY=<generate-secure-random-key>
